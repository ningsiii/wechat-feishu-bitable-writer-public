# formflow-agent environment template
# copy to solutions/formflow-agent/.env before running
#
# Model config boundary:
# 1) If you run formflow-agent as a standalone project, the model settings below
#    are used directly by the local scripts.
# 2) If you run formflow-agent inside OpenClaw / "小龙虾", OpenClaw's own model
#    config is primary. The variables below are still useful as local defaults,
#    but they do not automatically override OpenClaw's global model provider.
#
# These three variables should be understood as generic model settings:
# - DEEPSEEK_API_KEY: API key for the current OpenAI-compatible model endpoint
# - SMALLBIZ_MODEL_BASE_URL: base URL for the current model endpoint
# - SMALLBIZ_MODEL: model name at that endpoint

DEEPSEEK_API_KEY=
SMALLBIZ_MODEL_BASE_URL=https://api.deepseek.com
SMALLBIZ_MODEL=deepseek-chat

# v1 single-table defaults
SMALLBIZ_PROFILE=single
SMALLBIZ_ENABLE_ORGANIZE_REMINDER=0

# Runtime file locations (recommended for public pack)
# Use /tmp by default to avoid permission issues on mounted drives and to reduce accidental commits.
SMALLBIZ_DRAFT_FILE=/tmp/formflow-agent/draft.json
SMALLBIZ_LEDGER_PATH=/tmp/formflow-agent/ledger.jsonl
SMALLBIZ_EXPORT_DIR=/tmp/formflow-agent/exports

# optional wecom webhook (future)
WECOM_WEBHOOK_URL=
